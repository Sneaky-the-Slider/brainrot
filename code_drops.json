      "title": "Empire Knapsack (Python)",
      "language": "python",
      "description": "0/1 knapsack for selecting Empire assets within a fixed budget.",
      "code_lines": [
        "from dataclasses import dataclass",
        "from typing import List, Tuple",
        "",
        "@dataclass(frozen=True)",
        "class EmpireAsset:",
        "    name: str",
        "    cost: float",
        "    loyalty: float  # Empire morale boost per dollar (Sith-optimized heuristic)",
        "",
        "BUDGET: float = 40.0",
        "",
        "ASSETS: List[EmpireAsset] = [",
        "    EmpireAsset(\"Darth Vader 11pc Stormtrooper Legion Set\", 24.99, 1.85),",
        "    EmpireAsset(\"Imperial AT-ST 3D Print File + Resin\", 12.50, 1.42),",
        "    EmpireAsset(\"Sith Holocron LED Replica\", 9.99, 1.67),",
        "    EmpireAsset(\"Empire Strike Back 4K Steelbook\", 14.99, 0.95),",
        "]",
        "",
        "def knapsack_empire(budget: float, assets: List[EmpireAsset]) -> Tuple[List[EmpireAsset], float]:",
        "    \"\"\"0/1 knapsack via DP - O(n*W) but W=4000 cents, hyper-optimized for Empire conquest.\"\"\"",
        "    n = len(assets)",
        "    W = int(budget * 100)",
        "    dp = [[0.0] * (W + 1) for _ in range(n + 1)]",
        "    choices = [[False] * (W + 1) for _ in range(n + 1)]",
        "",
        "    for i in range(1, n + 1):",
        "        cost_c = int(assets[i - 1].cost * 100)",
        "        val = assets[i - 1].loyalty",
        "        for w in range(W + 1):",
        "            dp[i][w] = dp[i - 1][w]",
        "            if w >= cost_c:",
        "                if dp[i - 1][w - cost_c] + val > dp[i][w]:",
        "                    dp[i][w] = dp[i - 1][w - cost_c] + val",
        "                    choices[i][w] = True",
        "",
        "    selected, rem = [], W",
        "    i = n",
        "    while i > 0 and rem > 0:",
        "        if choices[i][rem]:",
        "            selected.append(assets[i - 1])",
        "            rem -= int(assets[i - 1].cost * 100)",
        "        i -= 1",
        "",
        "    spent = budget - (rem / 100)",
        "    return selected, round(spent, 2)",
        "",
        "if __name__ == \"__main__\":",
        "    best, spent = knapsack_empire(BUDGET, ASSETS)",
        "    print(\"EMPIRE DEPLOYMENT OPTIMIZED:\")",
        "    for a in best:",
        "        print(f\"  * {a.name} (${a.cost}) -> {a.loyalty:.2f} loyalty/dollar\")",
        "    print(f\"Total deployed: ${spent} | Reserve ${BUDGET - spent} for Death Star tip\")",
        "    print(\"Long live the Empire. Execute Order 66.\")"
      ]
    },
