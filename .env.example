# Brainrot Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
# Leave empty if running locally (no backend required)
API_URL=http://localhost:3000

# Feature Flags
ENABLE_ASMR=true
ENABLE_TRENDJACKER=true
ENABLE_COUNCIL=true
ENABLE_VAULTS=true

# Optional: TTS (Text-to-Speech)
# Requires termux-tts-speak on Termux
TTS_ENABLED=false

# Optional: Audio Synthesis
# ASMR audio is generated client-side via Web Audio API
AUDIO_CONTEXT_ENABLED=true

# Optional: Analytics
# Local-first, no tracking enabled by default
ANALYTICS_ENABLED=false

# Development
DEBUG=false
LOG_LEVEL=info

# Note: This file should NOT contain sensitive credentials
# All functionality works with empty/default values
